// The Hub data model. Prisma 7: `prisma-client` generator emits an ESM
// client into src/generated/prisma; the datasource URL is supplied by
// prisma.config.ts (dotenv), not inline here.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  SUPER_ADMIN
  ADMIN
  USER
  AGENCY
  BUSINESS_OWNER
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  displayName   String
  role          Role     @default(USER)
  emailVerified Boolean  @default(false)

  // Phone verification (scope §5, §12.1) — gate for posting reviews and
  // for taking a Location live. Set via OTP flow (later slice).
  phoneNumber   String?  @unique
  phoneVerified Boolean  @default(false)

  // Reputation derived from review history + votes received + moderation
  // (scope §4.4). Recomputed when votes/moderation change.
  reviewerScore Float    @default(0)

  // Soft delete (scope §6, §12.3): account removal keeps review integrity.
  isDeleted DateTime?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  interactions   InteractionEvent[]
  ownedLocations Location[]         @relation("LocationOwner")
  favorites      Favorite[]
  lists          List[]
  reviews        Review[]
  reviewVotes    ReviewVote[]
  claims         LocationClaim[]
  adminActions   AdminActionLog[]   @relation("AdminActor")
}

// Location category taxonomy (scope §3): a self-referential tree. Parent
// categories have parentId = null; subcategories point at their parent.
// Only English names are sourced today; ar/fr fall back to nameEn until
// translated. `slug` is the stable, locale-independent identifier.
model Category {
  id        String   @id @default(cuid())
  slug      String   @unique
  nameEn    String
  nameAr    String?
  nameFr    String?
  parentId  String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id], onDelete: Restrict)
  children Category[] @relation("CategoryTree")

  primaryLocations   Location[] @relation("LocationPrimary")
  secondaryLocations Location[] @relation("LocationSecondary")

  @@index([parentId])
}

model InteractionEvent {
  id        String   @id @default(cuid())
  userId    String?
  type      String
  metadata  Json     @default("{}")
  createdAt DateTime @default(now())

  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([type])
  @@index([createdAt])
}

// Listing lifecycle (scope §5). Approval transitions land in Phase 2; the
// status field exists from the start so search can surface only PUBLISHED.
enum ListingStatus {
  DRAFT
  PENDING
  PUBLISHED
  REJECTED
}

// A discoverable place (scope §4.3, §6). Geo is stored as plain lat/lng
// here; the PostGIS geography column + GiST index + radius queries are
// added in the search slice where distance filtering lives.
model Location {
  id          String        @id @default(cuid())
  name        String
  description String?
  status      ListingStatus @default(DRAFT)

  primaryCategoryId   String
  primaryCategory     Category   @relation("LocationPrimary", fields: [primaryCategoryId], references: [id], onDelete: Restrict)
  secondaryCategories Category[] @relation("LocationSecondary")
  tags                String[]

  latitude  Float?
  longitude Float?

  // Price tier 1–4 (scope §4.2 price filter), set at seed/claim.
  priceLevel Int?
  // Rating denormalized from Review for fast filter/sort; populated in
  // Phase 2 when reviews ship. Defaults reflect "no reviews yet".
  ratingAvg   Float?
  ratingCount Int    @default(0)

  hours           Json?
  // Address of record (scope §6/§9); also the natural dedup key for the
  // admin bulk import (scope §5.1). Nullable — Postgres permits many NULLs.
  googleMapsUrl   String?   @unique
  website         String?
  phoneNumber     String?
  phoneVerified   Boolean   @default(false)
  phoneVerifiedAt DateTime?

  // Owner is nullable until the listing is claimed (scope §6). Agency
  // ownership is added in Phase 3 (monetization).
  ownerUserId String?
  ownerUser   User?   @relation("LocationOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  claimed     Boolean @default(false)

  media     Media[]
  favorites Favorite[]
  listItems ListItem[]
  reviews   Review[]
  claims    LocationClaim[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([primaryCategoryId])
  @@index([status])
}

enum MediaType {
  PHOTO
  DOCUMENT
}

// Photos and documents attached to a Location (scope §6). Stored as
// signed/expiring object-storage URLs (S3/R2) — upload flow is Phase 2.
model Media {
  id         String    @id @default(cuid())
  locationId String
  location   Location  @relation(fields: [locationId], references: [id], onDelete: Cascade)
  url        String
  type       MediaType @default(PHOTO)
  sortOrder  Int       @default(0)
  createdAt  DateTime  @default(now())

  @@index([locationId])
}

// A user's quick-saved location (scope §4.5, §6). One row per
// (user, location) pair.
model Favorite {
  id         String   @id @default(cuid())
  userId     String
  locationId String
  createdAt  DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  location Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@unique([userId, locationId])
  @@index([userId])
}

// A user's custom grouping of locations (scope §4.5). When shared it
// carries a random, unguessable shareToken backing a public view-only link.
model List {
  id         String     @id @default(cuid())
  userId     String
  name       String
  isShared   Boolean    @default(false)
  shareToken String?    @unique
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items ListItem[]

  @@index([userId])
}

model ListItem {
  id         String   @id @default(cuid())
  listId     String
  locationId String
  note       String?
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())

  list     List     @relation(fields: [listId], references: [id], onDelete: Cascade)
  location Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@unique([listId, locationId])
  @@index([listId])
}

// Review moderation state (scope §4.4, §13). New reviews are VISIBLE;
// flagged ones move to PENDING for the queue and may end up REMOVED.
enum ModerationStatus {
  VISIBLE
  PENDING
  REMOVED
}

// One review per user per location (scope §4.4): editable, not duplicable.
// likes/dislikes are denormalized from ReviewVote for fast reads. Review
// photos are a documented follow-up (Media is Location-bound today).
model Review {
  id               String           @id @default(cuid())
  userId           String
  locationId       String
  rating           Int
  text             String?
  moderationStatus ModerationStatus @default(VISIBLE)
  likesCount       Int              @default(0)
  dislikesCount    Int              @default(0)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  user     User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  location Location   @relation(fields: [locationId], references: [id], onDelete: Cascade)
  votes    ReviewVote[]

  @@unique([userId, locationId])
  @@index([locationId])
  @@index([userId])
}

// A like (+1) or dislike (-1) on a review (scope §4.4): one per user per
// review, changeable. Rolls up into counts and the author's reviewerScore.
model ReviewVote {
  id        String   @id @default(cuid())
  userId    String
  reviewId  String
  value     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  review Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@unique([userId, reviewId])
  @@index([reviewId])
}

// Ownership claim on an existing listing (scope §5/§6). A business user
// claims an unclaimed Location; an admin approves or rejects. Approval
// sets the Location's owner and claimed flag. One pending claim per
// (user, location) — re-claiming after a decision is allowed.
enum ClaimStatus {
  PENDING
  APPROVED
  REJECTED
}

model LocationClaim {
  id         String      @id @default(cuid())
  userId     String
  locationId String
  status     ClaimStatus @default(PENDING)
  note       String?
  decidedBy  String?
  decidedAt  DateTime?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  location Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@index([locationId])
  @@index([userId])
  @@index([status])
}

// Append-only audit trail of privileged actions (scope §5 approval gate,
// §12 accountability). Every admin listing/claim decision writes one row.
model AdminActionLog {
  id          String   @id @default(cuid())
  adminUserId String
  action      String
  targetType  String
  targetId    String
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now())

  admin User @relation("AdminActor", fields: [adminUserId], references: [id], onDelete: Cascade)

  @@index([adminUserId])
  @@index([targetType, targetId])
}
