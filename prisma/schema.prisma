// The Hub data model. Prisma 7: `prisma-client` generator emits an ESM
// client into src/generated/prisma; the datasource URL is supplied by
// prisma.config.ts (dotenv), not inline here.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  SUPER_ADMIN
  ADMIN
  END_USER
  AGENCY
  INDIVIDUAL_LOCATION
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  displayName   String
  role          Role     @default(END_USER)
  emailVerified Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  interactions  InteractionEvent[]
}

// Location category taxonomy (scope §3): a self-referential tree. Parent
// categories have parentId = null; subcategories point at their parent.
// Only English names are sourced today; ar/fr fall back to nameEn until
// translated. `slug` is the stable, locale-independent identifier.
model Category {
  id        String   @id @default(cuid())
  slug      String   @unique
  nameEn    String
  nameAr    String?
  nameFr    String?
  parentId  String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id], onDelete: Restrict)
  children Category[] @relation("CategoryTree")

  @@index([parentId])
}

model InteractionEvent {
  id        String   @id @default(cuid())
  userId    String?
  type      String
  metadata  Json     @default("{}")
  createdAt DateTime @default(now())

  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([type])
  @@index([createdAt])
}
